# Copy to .env and fill in real values.  Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=chirpstack
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=chirpstack

# ChirpStack
# Generate with: openssl rand -base64 32
CHIRPSTACK_API_SECRET=change-me-generate-with-openssl-rand-base64-32

# InfluxDB
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-strong-password
INFLUXDB_ORG=culvertsense
INFLUXDB_BUCKET=sensors
INFLUXDB_ADMIN_TOKEN=change-me-long-random-token
